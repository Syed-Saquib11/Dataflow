{
  "name": "dataflow",
  "version": "1.0.0",
  "description": "DATAFLOW — Teacher Portal",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.dataflow.teacherportal",
    "productName": "DATAFLOW",
    "copyright": "Copyright © 2025",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "node_modules/**/*",
      "assets/**/*",
      ".env"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DATAFLOW"
    },
    "portable": {
      "artifactName": "DATAFLOW-Portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "docxtemplater": "^3.68.5",
    "dotenv": "^17.4.2",
    "googleapis": "^171.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "pdf-lib": "^1.17.1",
    "pizzip": "^3.2.0",
    "sqlite3": "^5.1.6"
  }
}
